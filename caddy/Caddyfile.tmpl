{$BOX_DOMAIN} {
    handle /oauth2/* {
        reverse_proxy oauth2-proxy:4180
    }

    @protected not path /oauth2/*
    forward_auth @protected oauth2-proxy:4180 {
        uri /oauth2/auth
        copy_headers X-Auth-Request-User X-Auth-Request-Email

        @unauthorized status 401
        handle_response @unauthorized {
            redir * /oauth2/sign_in?rd={scheme}://{host}{uri}
        }
    }

    # Only allowed_users (from config.yml) can access non-app paths.
    # /apps/* remains open to any authenticated user in the org.
    @not_allowed_user {
        not path /apps/*
        not path /oauth2/*
__ALLOWED_USERS_LINES__
    }
    respond @not_allowed_user "Forbidden" 403

    reverse_proxy box:8080 {
        transport http {
            keepalive 30s
            keepalive_idle_conns 10
        }
        @upstream_error status 404 502 503 504
        handle_response @upstream_error {
            error {rp.status_code}
        }
    }

    handle_errors {
        header Content-Type "text/html; charset=utf-8"
        respond <<ERRORPAGE
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Error {err.status_code}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #fafafa; color: #111; }
  .c { text-align: center; padding: 2rem; }
  h1 { font-size: 2rem; font-weight: 600; letter-spacing: -0.04em; line-height: 1; }
  p { margin-top: 0.75rem; font-size: 1.125rem; color: #666; }
</style>
</head>
<body>
<div class="c">
  <h1>{err.status_code}</h1>
  <p id="msg">Something went wrong.</p>
</div>
<script>
var code = "{err.status_code}";
var msg = "Something went wrong.";
if (code === "404") msg = "The app you're looking for doesn't exist.";
else if (code === "403") msg = "You don't have permission to access this page.";
else if (code === "502") msg = "The app isn't running or failed to respond.";
else if (code === "503") msg = "The app is temporarily unavailable. Try again in a moment.";
else if (code === "504") msg = "The app took too long to respond.";
document.getElementById("msg").textContent = msg;
</script>
</body>
</html>
ERRORPAGE {err.status_code}
    }
}
